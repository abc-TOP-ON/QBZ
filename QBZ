local function corner(instance, radius)
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, radius)
    UICorner.Parent = instance
    return UICorner
end

local function stroke(instance, color, thickness, transparency)
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = color
    UIStroke.Thickness = thickness
    UIStroke.Transparency = transparency or 0
    UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    UIStroke.Parent = instance
    return UIStroke
end

local function tween(instance, properties, duration, style)
    if not instance or not instance.Parent then return end
    duration = duration or 0.15
    style = style or Enum.EasingStyle.Quad
    local info = TweenInfo.new(duration, style, Enum.EasingDirection.Out)
    local t = TweetService:Create(instance, info, properties)
    t:Play()
    return t
end

local function verifyOwner()
    return true, LocalPlayer.Name, "Administrateur"
end

local function isWhitelisted(username)
    if Config.OpenMode then return true end
    if username == LocalPlayer.Name then return true end
    for _, name in pairs(Config.Whitelist) do
        if name:lower() == username:lower() then return true end
    end
    return false
end

local function addToWhitelist(username)
    if not isWhitelisted(username) then
        table.insert(Config.Whitelist, username)
    end
end

local function removeFromWhitelist(username)
    for i, name in pairs(Config.Whitelist) do
        if name:lower() == username:lower() then
            table.remove(Config.Whitelist, i)
            break
        end
    end
end

-- ===== Gestion des Messages =====
local function sendChatMessage(message)
    if Config.SilentMode or message == "" then return end
    
    local ok = pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local channel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if channel then
                channel:SendAsync(message)
            end
        else
            local chatEvents = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            local sayMessage = chatEvents and chatEvents:FindFirstChild("SayMessageRequest")
            if sayMessage then
                sayMessage:FireServer(message, "All")
            end
        end
    end)
    
    if not ok then
        warn("[Verity] Échec de l'envoi du message.")
    end
end

local function processMessage(sender, message)
    if sender == LocalPlayer then return end
    if not isWhitelisted(sender.Name) and not Config.OpenMode then return end

    local cleanMessage = string.lower(message)
    local senderName = sender.DisplayName or sender.Name
    lastInteractionTime = os.clock()

    if Config.AngryMode then
        for keyword, replies in pairs(AngryChatResponses) do
            if string.find(cleanMessage, keyword, 1, true) then
                local reply = replies[math.random(1, #replies)]
                sendChatMessage(string.gsub(reply, "{player}", senderName))
                return
            end
        end
    end

    for keyword, replies in pairs(ChatResponses) do
        if string.find(cleanMessage, keyword, 1, true) then
            local reply = replies[math.random(1, #replies)]
            sendChatMessage(string.gsub(reply, "{player}", senderName))
            return
        end
    end
end

