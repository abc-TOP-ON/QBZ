-- MESSAGES ALÉATOIRES (Boucle Idle)
-- =============================================================================
task.spawn(function()
    while true do
        local waitTime = math.random(Config.IdleIntervalMin, Config.IdleIntervalMax)
        task.wait(waitTime)
        if Config.AutoChatEnabled and (os.clock() - lastInteractionTime) >= waitTime then
            local phraseList = Config.AngryMode and Config.AngryIdleMessages or Config.IdleMessages
            if #phraseList > 0 then
                local phrase = phraseList[math.random(1, #phraseList)]
                sendChatMessage(phrase)
                crypticActive = (Config.AngryMode and phrase == Config.CrypticMessage)
                lastInteractionTime = os.clock()
            end
        end
    end
end)

-- =============================================================================
-- TOUCHES RAPIDES (KEYBINDS)
-- =============================================================================
local KeyAliases = {
    Ctrl = Enum.KeyCode.LeftControl,
    Shift = Enum.KeyCode.LeftShift,
    Alt = Enum.KeyCode.LeftAlt,
    Space = Enum.KeyCode.Space,
}

local function resolveKeyCode(keyName)
    keyName = keyName:gsub("^%s+", ""):gsub("%s+$", "")
    if KeyAliases[keyName] then return KeyAliases[keyName] end
    local ok, code = pcall(function() return Enum.KeyCode[keyName] end)
    if ok and code then return code end
    return nil
end

local ActiveKeybinds = {}

local function registerKeybind(keyName, phrase)
    local code = resolveKeyCode(keyName)
    if code then ActiveKeybinds[code] = phrase return true end
    return false
end

for keyName, phrase in pairs(Config.Keybinds) do registerKeybind(keyName, phrase) end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    local phrase = ActiveKeybinds[input.KeyCode]
    if phrase then task.spawn(function() sendChatMessage(phrase) end) end
end)

