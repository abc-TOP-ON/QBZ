local function safeProcessMessage(player, text)
    if not player or text == "" then return end
    pcall(processMessage, player, text)
end

if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if msg.TextSource then
            safeProcessMessage(Players:GetPlayerByUserId(msg.TextSource.UserId), msg.Text)
        end
    end)
else
    Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) safeProcessMessage(p, m) end) end)
    for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) safeProcessMessage(p, m) end) end
end

