-- =============================================================================
-- BOUCLE DE SUIVI (SÉCURISÉE)
-- =============================================================================
local blockCheckPos = nil
local blockCheckTime = os.clock()
local lastFollowUpdate = os.clock()

RunService.Heartbeat:Connect(function()
    if not ScreenGui.Parent then return end
    
    local ok, err = pcall(function()
        if not Config.FollowEnabled then
            StatusLabel.Text = "Suivi désactivé"
            blockCheckPos = nil
            return
        end

        if os.clock() - lastFollowUpdate < 0.25 then return end
        lastFollowUpdate = os.clock()

        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not (root and hum) then return end

        local target, dist = nil, math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local otherRoot = p.Character:FindFirstChild("HumanoidRootPart")
                if otherRoot then
                    local d = (root.Position - otherRoot.Position).Magnitude
                    if d < dist then dist = d; target = p end
                end
            end
        end

        if not target then return end

        if dist > Config.FollowDistance then
            local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                hum:MoveTo(targetRoot.Position)
                StatusLabel.Text = "Suivi : " .. (target.DisplayName or target.Name)

                if os.clock() - blockCheckTime > 0.5 then
                    if blockCheckPos and (root.Position - blockCheckPos).Magnitude < 1 then
                        hum.Jump = true
                    end
                    blockCheckPos = root.Position
                    blockCheckTime = os.clock()
                end
            end
        else
            StatusLabel.Text = "Cible rejointe"
            blockCheckPos = nil
        end
    end)

    if not ok then task.wait(0.5) end
end)

